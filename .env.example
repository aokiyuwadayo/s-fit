# ============================================================
# YUWA 環境変数テンプレート
# ============================================================
# 実際の値の取得方法は docs/setup-checklist.md を参照
# このファイルは git で追跡される。.env.local（実値）は .gitignore で除外
# ============================================================

# ------ Supabase ------
# Supabase Dashboard → Settings → Data API
# ローカル Supabase CLI を使う場合:
# 1. `supabase start`
# 2. `supabase status` の API URL / anon key / service_role key を .env.local に転記
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# ⚠ Service Role: サーバーサイドのみで使用。絶対公開しない
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ------ 匿名性 salt ------
# docs/requirements-v0.1.md §7 参照
# `openssl rand -base64 32` で生成し、パスワードマネージャに保存
# ⚠ 一度設定したら変えない（変えると過去の匿名投稿の同一性が壊れる）
ANONYMOUS_HASH_SALT=

# ------ Google OAuth ------
# Supabase Authentication → Providers → Google で設定済みなら、
# アプリ側で個別に持つ必要はない。バックアップ用として記載
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ------ Next.js ------
# 本番ドメイン（OAuth リダイレクト・OG image 等で参照）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
